APP_NAME=Compasse
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://compasse.net
ROOT_DOMAIN=compasse.net

# Tenancy (stancl/tenancy v3)
# The root domain. Tenant subdomains are {school}.compasse.net
TENANCY_ROOT_DOMAIN=compasse.net

# Frontend URL (used in email links, CORS, etc.)
FRONTEND_URL=https://compasse.net

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
PHP_CLI_SERVER_WORKERS=4
BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=daily
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=error

# ── Central Database (tenants, subscriptions, plans) ─────────────────────────
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=compasse_central
DB_USERNAME=compasse
DB_PASSWORD=your_db_password

# ── Session ───────────────────────────────────────────────────────────────────
SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
# Allow session sharing across all subdomains of compasse.net
SESSION_DOMAIN=.compasse.net

# ── Cache / Redis ─────────────────────────────────────────────────────────────
CACHE_STORE=redis
REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# ── Queues ────────────────────────────────────────────────────────────────────
QUEUE_CONNECTION=redis
BROADCAST_CONNECTION=reverb

# ── File Storage ──────────────────────────────────────────────────────────────
FILESYSTEM_DISK=s3

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=af-south-1
AWS_BUCKET=compasse-storage
AWS_USE_PATH_STYLE_ENDPOINT=false

# ── Mail ──────────────────────────────────────────────────────────────────────
MAIL_MAILER=smtp
MAIL_SCHEME=tls
MAIL_HOST=smtp.mailgun.org
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM_ADDRESS="hello@compasse.net"
MAIL_FROM_NAME="Compasse"

# ── SMS Providers ─────────────────────────────────────────────────────────────
# Options: termii | twilio | vonage | log
SERVICES_SMS_PROVIDER=termii
SERVICES_TERMII_KEY=
SERVICES_SMS_SENDER_ID=Compasse

SERVICES_TWILIO_SID=
SERVICES_TWILIO_TOKEN=
SERVICES_TWILIO_FROM=

SERVICES_VONAGE_KEY=
SERVICES_VONAGE_SECRET=
SERVICES_VONAGE_FROM=Compasse

# ── Sanctum (token auth) ──────────────────────────────────────────────────────
# Allow tokens from all subdomains of compasse.net
SANCTUM_STATEFUL_DOMAINS=compasse.net,*.compasse.net

# ── Reverb (WebSockets / real-time) ──────────────────────────────────────────
REVERB_APP_ID=
REVERB_APP_KEY=
REVERB_APP_SECRET=
REVERB_HOST=ws.compasse.net
REVERB_PORT=443
REVERB_SCHEME=https

VITE_APP_NAME="${APP_NAME}"
VITE_REVERB_APP_KEY="${REVERB_APP_KEY}"
VITE_REVERB_HOST="${REVERB_HOST}"
VITE_REVERB_PORT="${REVERB_PORT}"
VITE_REVERB_SCHEME="${REVERB_SCHEME}"
